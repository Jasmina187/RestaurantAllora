@using RestaurantAlloraProject.ViewModels.Dish
@model IEnumerable<DishViewModel>
<h2 class="text-center mb-4">🍽️ Menu</h2>
@if (User.IsInRole("Admin"))
{
    <a asp-controller="Dish" asp-action="Create" class="btn btn-warning mb-3">
        ➕ Add Dish
    </a>
}
<div class="row mb-4">
    <div class="col-md-6">
        <input type="text" id="searchInput" class="form-control" placeholder="🔍 Търси ястие...">
    </div>
    <div class="col-md-6">
        <select id="categoryFilter" class="form-select">
            <option value="">Всички категории</option>
            @foreach (var category in Model.Select(d => d.CategoryOfTheDish).Distinct())
            {
                <option value="@category">@category</option>
            }
        </select>
    </div>
</div>
<div class="row" id="menuContainer">
    @foreach (var dish in Model)
    {
        <div class="col-md-4 mb-4 dish-card"
             data-name="@dish.NameOfTheDish.ToLower()"
             data-category="@dish.CategoryOfTheDish">

            <div class="card h-100 shadow-sm menu-card">

                @if (!string.IsNullOrWhiteSpace(dish.ImageUrl))
                {
                    <img src="@dish.ImageUrl"
                         class="card-img-top"
                         style="height: 200px; object-fit: cover;" />
                }
                <div class="card-body d-flex flex-column">
                    <h5>
                        @dish.NameOfTheDish
                        <span class="badge bg-secondary">@dish.CategoryOfTheDish</span>
                    </h5>

                    <p class="text-muted small">@dish.DescriptionOfTheDish</p>

                    <p class="fw-bold text-success">
                        💰 @dish.PriceOfTheDish.ToString("0.00") €
                    </p>

                    @foreach (var allergen in dish.AllergenNames)
                    {
                        <p class="small text-danger">
                            @allergen
                        </p>
                    }
                    <div class="mt-auto">

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <form asp-controller="CustomerFavorite"
                                  asp-action="ToggleFavorite"
                                  method="post">

                                <input type="hidden" name="dishId" value="@dish.DishId" />

                                <button type="submit" class="btn btn-outline-danger w-100">
                                    ❤️ Любимо
                                </button>
                            </form>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="mt-2 d-flex gap-2">
                                <a asp-controller="Dish"
                                   asp-action="Edit"
                                   asp-route-id="@dish.DishId"
                                   class="btn btn-sm btn-outline-warning w-50">
                                    Edit
                                </a>

                                <form asp-controller="Dish"
                                      asp-action="Delete"
                                      asp-route-id="@dish.DishId"
                                      method="post" class="w-50">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-sm btn-outline-danger w-100"
                                            onclick="return confirm('Delete this dish?');">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        }

                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .menu-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .menu-card:hover {
            transform: scale(1.03);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }
</style>

<script>
    const searchInput = document.getElementById("searchInput");
    const categoryFilter = document.getElementById("categoryFilter");
    const cards = document.querySelectorAll(".dish-card");

    function filterMenu() {
        const search = searchInput.value.toLowerCase();
        const category = categoryFilter.value;

        cards.forEach(card => {
            const name = card.dataset.name;
            const cat = card.dataset.category;

            const matchSearch = name.includes(search);
            const matchCategory = !category || cat === category;

            card.style.display = (matchSearch && matchCategory) ? "block" : "none";
        });
    }

    searchInput.addEventListener("input", filterMenu);
    categoryFilter.addEventListener("change", filterMenu);
</script>