@using RestaurantAlloraProject.ViewModels.Dish
@model IEnumerable<DishViewModel>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Онлайн Меню";
    var categories = Model.Select(d => d.CategoryOfTheDish).Distinct().ToList();
}

<div class="menu-layout">
    <div class="menu-main">
        <h1 class="allora-title text-center mb-4">Меню Allora</h1>

        <div class="category-pills mb-5 text-center">
            <button class="pill-btn active js-menu-filter" data-category="all">Всички</button>
            @foreach (var category in categories)
            {
                <button class="pill-btn js-menu-filter" data-category="@category">@category</button>
            }
        </div>

        <div class="dishes-grid">
            @foreach (var dish in Model)
            {
                <div class="dish-card" data-category="@dish.CategoryOfTheDish">
                    <div class="dish-img-wrapper">
                        <img src="@dish.ImageUrl" alt="@dish.NameOfTheDish">
                    </div>

                    <div class="dish-info">
                        <h4 class="dish-name">@dish.NameOfTheDish</h4>
                        <p class="dish-desc">@dish.DescriptionOfTheDish</p>

                        <div class="dish-action mt-auto">
                            <span class="dish-price">@dish.PriceOfTheDish.ToString("0.00") €</span>

                            <button class="add-btn js-add-to-cart"
                                    data-dish-id="@dish.DishId"
                                    data-dish-name="@dish.NameOfTheDish"
                                    data-dish-price="@dish.PriceOfTheDish.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)">
                                Добави
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="cart-sidebar">
        <h3 class="cart-title">Вашата поръчка</h3>

        <div id="cart-items" class="cart-items">
            <div class="empty-cart text-center text-muted mt-5">
                <p>Количката е празна</p>
            </div>
        </div>

        <div class="cart-footer">
            @Html.AntiForgeryToken()
            <div class="d-flex justify-content-between mb-3">
                <span class="cart-total-label">Общо:</span>
                <span id="cart-total" class="cart-total-value">0.00 €</span>
            </div>

            @if (User.IsInRole("Customer"))
            {
                <button id="checkout-btn" class="checkout-btn" disabled>Поръчай</button>
            }
            else
            {
                <a asp-controller="User"
                   asp-action="LogIn"
                   class="checkout-btn text-center d-block text-decoration-none">
                    Влез като клиент, за да поръчаш
                </a>
            }
        </div>
    </div>
</div>

