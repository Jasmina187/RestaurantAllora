@using RestaurantAlloraProjectViewModels.Dish
@model DishEditViewModel

<h2 class="dish-form-title">Редакция на ястие</h2>

<form asp-action="Edit" method="post" asp-controller="Dish" enctype="multipart/form-data" class="dish-form-card">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ImageUrl" />

    <div class="mb-3">
        <label asp-for="NameOfTheDish" class="form-label">Име</label>
        <input asp-for="NameOfTheDish" class="form-control" />
        <span asp-validation-for="NameOfTheDish" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DescriptionOfTheDish" class="form-label">Описание</label>
        <textarea asp-for="DescriptionOfTheDish" class="form-control"></textarea>
        <span asp-validation-for="DescriptionOfTheDish" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PriceOfTheDish" class="form-label">Цена (€)</label>
        <input asp-for="PriceOfTheDish" class="form-control" />
        <span asp-validation-for="PriceOfTheDish" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CategoryOfTheDish" class="form-label">Категория</label>
        <select asp-for="CategoryOfTheDish" asp-items="ViewBag.Categories" class="form-select"></select>
        <span asp-validation-for="CategoryOfTheDish" class="text-danger"></span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
    {
        <div class="mb-3">
            <img src="@Model.ImageUrl" alt="@Model.NameOfTheDish" style="max-width: 220px; height: auto;" />
        </div>
    }

    <div class="mb-3">
        <label asp-for="Picture" class="form-label">Качи нова снимка</label>
        <input asp-for="Picture" type="file" accept="image/gif,image/jpeg,image/png,image/webp" class="form-control" />
        <span asp-validation-for="Picture" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Алергени</label>
        <select asp-for="SelectedAllergenIds"
                asp-items="ViewBag.Allergens"
                id="allergensSelect"
                multiple
                class="form-select">
        </select>
        <span asp-validation-for="SelectedAllergenIds" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Запази</button>
    <a asp-controller="Dish" asp-action="Index" class="btn btn-secondary">Назад</a>
</form>

