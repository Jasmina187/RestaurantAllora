@using RestaurantAlloraProjectViewModels.Category
@model CategoryViewModel

@{
    ViewData["Title"] = "Нова категория";
}

<div class="container mt-5">
    <h2>Нова категория</h2>

    <form asp-action="Create" method="post" class="mt-4">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label">Име</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Запази</button>
        <a asp-action="Index" class="btn btn-secondary">Назад</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
