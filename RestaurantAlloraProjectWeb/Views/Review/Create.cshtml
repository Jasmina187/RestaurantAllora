@using RestaurantAlloraProjectViewModels.Review
@model ReviewViewModel
@{
    ViewData["Title"] = "Създай ревю";
}

<h2>Създай ново ревю</h2>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Add" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="DishId" />
            <input type="hidden" asp-for="CustomerId" />

            <div class="form-group mb-3">
                <label asp-for="Rating" class="control-label">Оценка (1-5)</label>
                <input asp-for="Rating" class="form-control" type="number" min="1" max="5" />
                <span asp-validation-for="Rating" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Comment" class="control-label">Коментар</label>
                <textarea asp-for="Comment" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Comment" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Създай</button>
                <a asp-controller="Dish" asp-action="ClientMenu" class="btn btn-secondary">Назад към менюто</a>
            </div>
        </form>
    </div>
</div>

