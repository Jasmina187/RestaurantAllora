@using RestaurantAlloraProjectViewModels.Review
@model ReviewListViewModel

@{
    ViewData["Title"] = "Всички ревюта";
}

<div class="container mt-5 review-page">
    <h2>Списък с ревюта</h2>

    @if (!Model.Reviews.Any())
    {
        <div class="alert alert-info mt-3">Все още няма добавени ревюта.</div>
    }
    else
    {
        <table class="table table-striped table-hover mt-3">
            <thead class="table-dark">
                <tr>
                    <th>Ястие</th>
                    <th>Оценка</th>
                    <th>Коментар</th>
                    <th>Дата</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Reviews)
                {
                    <tr>
                        <td>@(string.IsNullOrWhiteSpace(item.DishName) ? item.DishId : item.DishName)</td>
                        <td>
                            <span class="text-warning">
                                @for (int i = 0; i < item.Rating; i++)
                                {
                                    <i class="fas fa-star"></i>
                                }
                            </span>
                            (@item.Rating)
                        </td>
                        <td>@item.Comment</td>
                        <td>@item.CreatedOn.ToString("dd.MM.yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Пагинация на ревютата" class="mt-4">
                <ul class="pagination justify-content-center flex-wrap gap-1">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        @if (Model.HasPreviousPage)
                        {
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)">Предишна</a>
                        }
                        else
                        {
                            <span class="page-link">Предишна</span>
                        }
                    </li>

                    @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                    {
                        <li class="page-item @(pageNumber == Model.CurrentPage ? "active" : "")">
                            @if (pageNumber == Model.CurrentPage)
                            {
                                <span class="page-link">@pageNumber</span>
                            }
                            else
                            {
                                <a class="page-link" asp-action="Index" asp-route-page="@pageNumber">@pageNumber</a>
                            }
                        </li>
                    }

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        @if (Model.HasNextPage)
                        {
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)">Следваща</a>
                        }
                        else
                        {
                            <span class="page-link">Следваща</span>
                        }
                    </li>
                </ul>
            </nav>
        }
    }
</div>
