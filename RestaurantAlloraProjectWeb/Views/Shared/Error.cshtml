@model ErrorViewModel
@{
    ViewData["Title"] = "Възникна грешка";
}

<section class="status-page">
    <span class="menu-eyebrow">Ресторант Allora</span>
    <h1>Нещо се обърка.</h1>
    <p>Опитайте отново след малко или се върнете към началната страница.</p>

    @if (Model.ShowRequestId)
    {
        <p class="status-muted">
            Номер на заявка: <code>@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="status-action">Към началото</a>
</section>
