@using RestaurantAlloraProjectViewModels.Table
@model IEnumerable<TableViewModel>

@{
    Layout = "_Layout";
    int? selectedCapacity = ViewBag.SelectedCapacity as int?;
    int? autoMinCapacity = selectedCapacity.HasValue ? selectedCapacity.Value >= 8 ? 8 : selectedCapacity.Value : null;
    int? autoMaxCapacity = selectedCapacity.HasValue ? selectedCapacity.Value >= 8 ? 10 : selectedCapacity.Value : null;
}

<div class="luxury-container" data-auto-min-cap="@autoMinCapacity" data-auto-max-cap="@autoMaxCapacity">
    <div class="header-content text-center">
        <h1 class="allora-title">Allora Experience</h1>
        <p class="allora-subtitle">Изберете перфектната обстановка според броя на Вашите гости</p>
    </div>

    <div class="category-grid">

        <div class="category-item js-table-filter" data-min-cap="2" data-max-cap="2">
            <div class="img-wrapper">
                <img src="https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?q=80&w=800" alt="Romantic">
                <div class="overlay">
                    <span class="cap-number">2</span>
                    <h3>Романтика</h3>
                    <p>Маса за двама</p>
                </div>
            </div>
        </div>

        <div class="category-item js-table-filter" data-min-cap="4" data-max-cap="4">
            <div class="img-wrapper">
                <img src="https://images.pexels.com/photos/1581554/pexels-photo-1581554.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Friends">
                <div class="overlay">
                    <span class="cap-number">4</span>
                    <h3>Приятели</h3>
                    <p>Маса за четирима</p>
                </div>
            </div>
        </div>

        <div class="category-item js-table-filter" data-min-cap="6" data-max-cap="6">
            <div class="img-wrapper">
                <img src="https://images.pexels.com/photos/1537635/pexels-photo-1537635.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Family">
                <div class="overlay">
                    <span class="cap-number">6</span>
                    <h3>Семейство</h3>
                    <p>Маса за шестима</p>
                </div>
            </div>
        </div>

        <div class="category-item js-table-filter" data-min-cap="8" data-max-cap="10">
            <div class="img-wrapper">
                <img src="https://images.pexels.com/photos/3184183/pexels-photo-3184183.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Party">
                <div class="overlay">
                    <span class="cap-number">8+</span>
                    <h3>Празненство</h3>
                    <p>От 8 до 10 места</p>
                </div>
            </div>
        </div>

    </div>

    <div id="results-area" class="results-hidden">
        <h2 id="filter-title" class="text-center mb-4"></h2>
        <div class="table-status-legend">
            <span><i class="legend-dot legend-dot-available"></i>Свободна</span>
            <span><i class="legend-dot legend-dot-pending"></i>Очаква одобрение</span>
            <span><i class="legend-dot legend-dot-reserved"></i>Резервирана</span>
        </div>
        <div id="table-reservation-info" class="table-reservation-info" aria-live="polite"></div>
        <div class="tables-flex-grid">
            @foreach (var table in Model)
            {
                var hasApprovedReservation = table.ActiveReservationStarts.Any();
                var hasPendingReservation = table.PendingReservationStarts.Any();
                var tableStatus = hasApprovedReservation ? "Резервирана" : hasPendingReservation ? "Очаква одобрение" : "Свободна";
                var statusClass = hasApprovedReservation ? "table-card-reserved" : hasPendingReservation ? "table-card-pending" : "table-card-available";
                var reservationRanges = string.Join("|", table.ActiveReservationStarts.Select(start => $"{start:dd.MM.yyyy} от {start:HH:mm} до {start.AddHours(3):HH:mm}"));
                var pendingRanges = string.Join("|", table.PendingReservationStarts.Select(start => $"{start:dd.MM.yyyy} от {start:HH:mm} до {start.AddHours(3):HH:mm}"));

                <a asp-controller="Reservation" asp-action="Create" asp-route-tableId="@table.TableId"
                   class="luxury-table-card @statusClass"
                   data-cap="@table.CapacityOfTheTable"
                   data-table-number="@table.TableNumber"
                   data-reservation-ranges="@reservationRanges"
                   data-pending-ranges="@pendingRanges">
                    <div class="table-inner">
                        <span class="t-num">#@table.TableNumber</span>
                        <span class="t-cap">@table.CapacityOfTheTable места</span>
                        <span class="t-status">@tableStatus</span>
                    </div>
                </a>
            }
        </div>
    </div>
</div>

