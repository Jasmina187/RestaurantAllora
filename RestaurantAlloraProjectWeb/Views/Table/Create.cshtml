@using RestaurantAlloraProjectViewModels.Table
@model TableViewModel
<h2>Нова маса</h2>
<form asp-action="Create" method="post">

    <div class="mb-3">
        <label asp-for="@Model.TableNumber" class="form-label">Номер</label>
        <input asp-for="@Model.TableNumber" class="form-control" />
        <span asp-validation-for="TableNumber" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="@Model.CapacityOfTheTable" class="form-label">Капацитет</label>
        <input asp-for="@Model.CapacityOfTheTable" class="form-control" />
        <span asp-validation-for="CapacityOfTheTable" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="@Model.StatusOfTheTable" class="form-label">Статус</label>
        <input asp-for="@Model.StatusOfTheTable" class="form-control" />
        <span asp-validation-for="StatusOfTheTable" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Запази</button>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</form>
