@using System.Globalization
@model IEnumerable<RestaurantAlloraProject.ViewModels.CustomerFavorite.CustomerFavoriteViewModel>

@{
    ViewData["Title"] = "Моите любими ястия";
    var favorites = Model.ToList();
}

<section class="favorites-page">
    <div class="favorites-heading">
        <div>
            <span class="menu-eyebrow">Ресторант Allora</span>
            <h1 class="allora-title">Моите любими ястия</h1>
            <p class="favorites-lead">Запази вкусовете, към които винаги се връщаш.</p>
        </div>

        @if (favorites.Any())
        {
            <a asp-controller="Dish" asp-action="Index" class="favorite-menu-link">
                Разгледай менюто
            </a>
        }
    </div>

    @if (!favorites.Any())
    {
        <div class="favorites-empty">
            <div class="favorites-empty-copy">
                <span class="favorites-empty-kicker">Още няма фаворити</span>
                <h2>Запази ястията, към които искаш да се връщаш.</h2>
                <p>Разгледай менюто и отбележи любимите си предложения. Те ще се появят тук за по-бърза следваща поръчка.</p>
                <div class="favorites-empty-actions">
                    <a asp-controller="Dish" asp-action="Index" class="favorite-primary-action">
                        Разгледай менюто
                    </a>
                    <a asp-controller="Dish" asp-action="ClientMenu" class="favorite-secondary-action">
                        Онлайн поръчка
                    </a>
                </div>
            </div>
            <div class="favorites-empty-preview" aria-hidden="true">
                <img src="~/img/allora-hero.jpg" alt="" class="favorites-empty-image" loading="lazy" />
                <div class="favorites-empty-note">
                    <span>Любимо</span>
                    <strong>Първото ти ястие чака в менюто</strong>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="favorites-summary">
            <span>@favorites.Count любими</span>
        </div>

        <div class="favorites-grid">
            @foreach (var dish in favorites.OrderByDescending(d => d.AddedOn))
            {
                var imageUrl = string.IsNullOrWhiteSpace(dish.ImageUrl)
                    ? Url.Content("~/img/allora-hero.jpg")
                    : dish.ImageUrl;

                <article class="favorite-card">
                    <a asp-controller="Dish"
                       asp-action="Index"
                       class="favorite-image-link"
                       aria-label="Виж @dish.DishName в менюто">
                        <img src="@imageUrl"
                             alt="@dish.DishName"
                             class="favorite-card-img"
                             loading="lazy" />
                    </a>

                    <div class="favorite-card-body">
                        <div class="favorite-card-topline">
                            <span class="favorite-pill">Любимо</span>
                            <span class="favorite-price">@dish.Price.ToString("0.00") €</span>
                        </div>

                        <h2 class="favorite-dish-title">@dish.DishName</h2>
                        <p class="favorite-added">Добавено на @dish.AddedOn.ToString("dd.MM.yyyy")</p>

                        <div class="favorite-actions">
                            <button type="button"
                                    class="favorite-primary-action favorite-order-action js-add-to-cart"
                                    data-dish-id="@dish.DishId"
                                    data-dish-name="@dish.DishName"
                                    data-dish-price="@dish.Price.ToString("0.00", CultureInfo.InvariantCulture)"
                                    data-redirect-url="@Url.Action("ClientMenu", "Dish")">
                                Поръчай
                            </button>

                            <a asp-controller="Review"
                               asp-action="Add"
                               asp-route-dishId="@dish.DishId"
                               asp-route-returnUrl="@Url.Action("Index", "CustomerFavorite")"
                               class="favorite-secondary-action">
                                Оцени
                            </a>

                            <form asp-controller="CustomerFavorite"
                                  asp-action="ToggleFavorite"
                                  method="post"
                                  class="favorite-remove-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="dishId" value="@dish.DishId" />
                                <button type="submit" class="favorite-remove-action">
                                    Премахни
                                </button>
                            </form>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>
