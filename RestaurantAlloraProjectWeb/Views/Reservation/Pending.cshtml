@using RestaurantAlloraProjectViewModels.Reservation
@model ReservationManagementViewModel

@{
    var selectedStatus = Model.Filter.Status ?? "Всички";
    var filterDate = Model.Filter.Date?.ToString("yyyy-MM-dd");
}

<div class="reservation-page">
    <h2>Управление на резервации</h2>

    @if (TempData["ReservationSuccess"] != null)
    {
        <div class="alert alert-success mt-3">@TempData["ReservationSuccess"]</div>
    }

    @if (TempData["ReservationError"] != null)
    {
        <div class="alert alert-danger mt-3">@TempData["ReservationError"]</div>
    }

    <form asp-action="Pending" method="get" class="reservation-filter mt-3 mb-4">
        <input type="hidden" name="Page" value="1" />
        <input type="hidden" name="PageSize" value="10" />

        <div>
            <label for="Status" class="form-label">Статус</label>
            <select id="Status" name="Status" class="form-select">
                @foreach (var status in Model.Statuses)
                {
                    <option value="@status" selected="@(status == selectedStatus)">@status</option>
                }
            </select>
        </div>

        <div>
            <label for="Date" class="form-label">Дата</label>
            <input id="Date" name="Date" type="date" class="form-control" value="@filterDate" />
        </div>

        <div>
            <label for="TableNumber" class="form-label">Маса</label>
            <input id="TableNumber" name="TableNumber" type="number" min="1" class="form-control" value="@Model.Filter.TableNumber" />
        </div>

        <div>
            <label for="SearchTerm" class="form-label">Клиент или служител</label>
            <input id="SearchTerm" name="SearchTerm" class="form-control" value="@Model.Filter.SearchTerm" />
        </div>

        <div class="reservation-filter-actions">
            <button type="submit" class="btn btn-primary">Филтрирай</button>
            <a asp-action="Pending" class="btn btn-secondary">Изчисти</a>
        </div>
    </form>

    @if (!Model.Reservations.Any())
    {
        <p class="mt-3">Няма резервации по избраните критерии.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped align-middle mt-3">
                <thead>
                    <tr>
                        <th>Дата</th>
                        <th>Клиент</th>
                        <th>Маса</th>
                        <th>Капацитет</th>
                        <th>Гости</th>
                        <th>Резервация</th>
                        <th>Маса статус</th>
                        <th>Служител</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reservation in Model.Reservations)
                    {
                        var badgeClass = reservation.Status switch
                        {
                            "Одобрена" => "text-bg-success",
                            "Отказана" => "text-bg-danger",
                            _ => "text-bg-warning"
                        };

                        <tr>
                            <td>@reservation.ReservationDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@(string.IsNullOrWhiteSpace(reservation.CustomerName) ? "-" : reservation.CustomerName)</td>
                            <td>@reservation.TableNumber</td>
                            <td>@reservation.CapacityOfTheTable</td>
                            <td>@reservation.NumberOfGuests</td>
                            <td><span class="badge @badgeClass">@reservation.Status</span></td>
                            <td>@reservation.StatusOfTheTable</td>
                            <td>@(string.IsNullOrWhiteSpace(reservation.EmployeeName) ? "-" : reservation.EmployeeName)</td>
                            <td>
                                @if (reservation.CanApprove || reservation.CanReject)
                                {
                                    <div class="d-flex gap-2">
                                        @if (reservation.CanApprove)
                                        {
                                            <form asp-action="Approve" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@reservation.ReservationId" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-success"
                                                        data-confirm="Да одобрим ли тази резервация?">
                                                    Одобри
                                                </button>
                                            </form>
                                        }

                                        @if (reservation.CanReject)
                                        {
                                            <form asp-action="Reject" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@reservation.ReservationId" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-danger"
                                                        data-confirm="Да откажем ли тази резервация?">
                                                    Откажи
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Пагинация на резервациите" class="mt-4">
                <ul class="pagination justify-content-center flex-wrap gap-1">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        @if (Model.HasPreviousPage)
                        {
                            <a class="page-link"
                               asp-action="Pending"
                               asp-route-Status="@Model.Filter.Status"
                               asp-route-Date="@filterDate"
                               asp-route-TableNumber="@Model.Filter.TableNumber"
                               asp-route-SearchTerm="@Model.Filter.SearchTerm"
                               asp-route-Page="@(Model.CurrentPage - 1)"
                               asp-route-PageSize="10">Предишна</a>
                        }
                        else
                        {
                            <span class="page-link">Предишна</span>
                        }
                    </li>

                    @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                    {
                        <li class="page-item @(pageNumber == Model.CurrentPage ? "active" : "")">
                            @if (pageNumber == Model.CurrentPage)
                            {
                                <span class="page-link">@pageNumber</span>
                            }
                            else
                            {
                                <a class="page-link"
                                   asp-action="Pending"
                                   asp-route-Status="@Model.Filter.Status"
                                   asp-route-Date="@filterDate"
                                   asp-route-TableNumber="@Model.Filter.TableNumber"
                                   asp-route-SearchTerm="@Model.Filter.SearchTerm"
                                   asp-route-Page="@pageNumber"
                                   asp-route-PageSize="10">@pageNumber</a>
                            }
                        </li>
                    }

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        @if (Model.HasNextPage)
                        {
                            <a class="page-link"
                               asp-action="Pending"
                               asp-route-Status="@Model.Filter.Status"
                               asp-route-Date="@filterDate"
                               asp-route-TableNumber="@Model.Filter.TableNumber"
                               asp-route-SearchTerm="@Model.Filter.SearchTerm"
                               asp-route-Page="@(Model.CurrentPage + 1)"
                               asp-route-PageSize="10">Следваща</a>
                        }
                        else
                        {
                            <span class="page-link">Следваща</span>
                        }
                    </li>
                </ul>
            </nav>
        }
    }
</div>
