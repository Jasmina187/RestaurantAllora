@using RestaurantAlloraProjectViewModels.Reservation
@model ReservationListViewModel

<div class="reservation-page">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Моите резервации</h2>
        <a asp-action="Create" class="btn btn-success">+ Нова резервация</a>
    </div>

    @if (!Model.Reservations.Any())
    {
        <p class="mt-3">Нямаш резервации.</p>
    }
    else
    {
        <table class="table table-striped mt-3">
            <thead>
                <tr>
                    <th>Дата</th>
                    <th>Маса</th>
                    <th>Капацитет</th>
                    <th>Гости</th>
                    <th>Статус</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Reservations)
                {
                    <tr>
                        <td>@r.ReservationDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@r.TableNumber</td>
                        <td>@r.CapacityOfTheTable</td>
                        <td>@r.NumberOfGuests</td>
                        <td>@r.Status</td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Пагинация на резервациите" class="mt-4">
                <ul class="pagination justify-content-center flex-wrap gap-1">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        @if (Model.HasPreviousPage)
                        {
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)">Предишна</a>
                        }
                        else
                        {
                            <span class="page-link">Предишна</span>
                        }
                    </li>

                    @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                    {
                        <li class="page-item @(pageNumber == Model.CurrentPage ? "active" : "")">
                            @if (pageNumber == Model.CurrentPage)
                            {
                                <span class="page-link">@pageNumber</span>
                            }
                            else
                            {
                                <a class="page-link" asp-action="Index" asp-route-page="@pageNumber">@pageNumber</a>
                            }
                        </li>
                    }

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        @if (Model.HasNextPage)
                        {
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)">Следваща</a>
                        }
                        else
                        {
                            <span class="page-link">Следваща</span>
                        }
                    </li>
                </ul>
            </nav>
        }
    }
</div>
