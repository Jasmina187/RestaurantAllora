@using RestaurantAlloraProjectViewModels.Order
@model OrderViewModel

@{
    ViewData["Title"] = "Финализиране на поръчка";
    var items = Model.CustomerOrderItems?.ToList() ?? new List<RestaurantAlloraProjectViewModels.CustomerOrderItem.CustomerOrderItemViewModel>();
}

<div class="container">
    <div class="order-container">
        <h2 class="order-header"><i class="fas fa-utensils me-2"></i> Финализиране на поръчка</h2>

        @if (!items.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-shopping-basket fa-4x text-muted mb-3"></i>
                <h4 class="text-muted">Количката ви е празна.</h4>
                <a asp-controller="Dish" asp-action="Index" class="btn btn-outline-danger btn-lg mt-3">Разгледайте менюто</a>
            </div>
        }
        else
        {
            <form asp-action="Create" method="post" class="checkout-form">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="TotalAmount" />

                @for (var i = 0; i < items.Count; i++)
                {
                    <input type="hidden" name="CustomerOrderItems[@i].DishId" value="@items[i].DishId" />
                    <input type="hidden" name="CustomerOrderItems[@i].DishName" value="@items[i].DishName" />
                    <input type="hidden" name="CustomerOrderItems[@i].Quantity" value="@items[i].Quantity" />
                    <input type="hidden" name="CustomerOrderItems[@i].Price" value="@items[i].Price" />
                }

                <div class="row g-4">
                    <div class="col-lg-7">
                        <h4 class="mb-3 border-bottom pb-2">Данни за поръчката</h4>

                        <div class="checkout-methods mb-3">
                            <label class="checkout-method">
                                <input asp-for="FulfillmentType" type="radio" value="Вземане на място" />
                                <span>
                                    <strong>Вземане на място</strong>
                                    <small>Ще вземете поръчката лично от ресторанта.</small>
                                </span>
                            </label>

                            <label class="checkout-method">
                                <input asp-for="FulfillmentType" type="radio" value="Доставка" />
                                <span>
                                    <strong>Доставка</strong>
                                    <small>Ще доставим поръчката до посочения адрес.</small>
                                </span>
                            </label>
                        </div>
                        <span asp-validation-for="FulfillmentType" class="text-danger"></span>

                        <div class="mb-3">
                            <label asp-for="CustomerFullName" class="form-label">Име и фамилия</label>
                            <input asp-for="CustomerFullName" class="form-control" autocomplete="name" />
                            <span asp-validation-for="CustomerFullName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CustomerPhone" class="form-label">Телефон</label>
                            <input asp-for="CustomerPhone" class="form-control" autocomplete="tel" />
                            <span asp-validation-for="CustomerPhone" class="text-danger"></span>
                        </div>

                        <div class="mb-3 checkout-delivery-address">
                            <label asp-for="DeliveryAddress" class="form-label">Адрес за доставка</label>
                            <input asp-for="DeliveryAddress" class="form-control" autocomplete="street-address" />
                            <span asp-validation-for="DeliveryAddress" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label">Бележка към поръчката</label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-lg-5">
                        <h4 class="mb-3 border-bottom pb-2">Артикули</h4>

                        <div class="items-list">
                            @foreach (var item in items)
                            {
                                <div class="item-card">
                                    <div class="order-item-details">
                                        <div class="fw-bold order-item-name">@item.DishName</div>
                                        <div class="text-muted">@item.Price.ToString("F2") € / порция</div>
                                    </div>
                                    <div class="text-end">
                                        <div>x @item.Quantity</div>
                                        <strong>@((item.Quantity * item.Price).ToString("F2")) €</strong>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="total-section mt-3">
                            <span class="text-uppercase text-muted total-label">Общо за плащане</span>
                            <h2 class="mb-0 text-warning fw-bold">@Model.TotalAmount.ToString("F2") €</h2>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <a asp-controller="Dish" asp-action="ClientMenu" class="btn btn-secondary">Назад към менюто</a>
                            <button type="submit" class="btn-checkout">Потвърди поръчката</button>
                        </div>
                    </div>
                </div>
            </form>
        }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const deliveryAddress = document.querySelector(".checkout-delivery-address");
            const methodInputs = document.querySelectorAll('input[name="FulfillmentType"]');

            function syncDeliveryAddress() {
                const selectedMethod = document.querySelector('input[name="FulfillmentType"]:checked');
                const isDelivery = selectedMethod && selectedMethod.value === "Доставка";

                if (deliveryAddress) {
                    deliveryAddress.classList.toggle("d-none", !isDelivery);
                }
            }

            methodInputs.forEach(input => input.addEventListener("change", syncDeliveryAddress));
            syncDeliveryAddress();
        })();
    </script>
}
