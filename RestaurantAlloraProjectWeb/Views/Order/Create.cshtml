@using RestaurantAlloraProjectViewModels.Order
@model OrderViewModel

@{
    ViewData["Title"] = "Вашата поръчка";
}

<div class="container">
    <div class="order-container">
        <h2 class="order-header"><i class="fas fa-utensils me-2"></i> Количка, Allora!</h2>

        @if (Model.CustomerOrderItems == null || !Model.CustomerOrderItems.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-shopping-basket fa-4x text-muted mb-3"></i>
                <h4 class="text-muted">Количката ви е празна.</h4>
                <a asp-controller="Dish" asp-action="Index" class="btn btn-outline-danger btn-lg mt-3">Разгледайте менюто</a>
            </div>
        }
        else
        {
            <div class="items-list">
                @foreach (var item in Model.CustomerOrderItems)
                {
                    <div class="item-card flex-column flex-md-row">
                        <div class="mb-3 mb-md-0 order-item-details">
                            <div class="fw-bold order-item-name">@item.DishName</div>
                            <div class="text-muted">@item.Price.ToString("F2") лв. / порция</div>
                        </div>

                        <form asp-controller="CustomerOrderItem" asp-action="UpdateQuantity" method="post" class="d-flex align-items-center mb-3 mb-md-0 mx-md-4">
                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="number" name="quantity" class="form-control text-center me-2 order-quantity-input" value="@item.Quantity" min="1" />
                            <button type="submit" class="btn-update"><i class="fas fa-sync-alt"></i></button>
                        </form>

                        <div class="fw-bold mb-3 mb-md-0 text-center mx-md-4 order-item-total">
                            @((item.Quantity * item.Price).ToString("F2")) лв.
                        </div>

                        <form asp-controller="CustomerOrderItem" asp-action="Delete" method="post">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn-remove" title="Премахни">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </form>
                    </div>
                }
            </div>

            <div class="total-section d-flex flex-column flex-md-row align-items-center justify-content-between">
                <div>
                    <span class="text-uppercase text-muted total-label">Общо за плащане</span>
                    <h2 class="mb-0 text-warning fw-bold">@Model.TotalAmount.ToString("F2") лв.</h2>
                </div>

                <div class="mt-4 mt-md-0">
                    <form asp-action="Create" method="post">
                        <input type="hidden" asp-for="CustomerId" />
                        <input type="hidden" asp-for="TotalAmount" />

                        @for (int i = 0; i < Model.CustomerOrderItems.Count; i++)
                        {
                            <input type="hidden" asp-for="CustomerOrderItems.ElementAt(i).DishId" />
                            <input type="hidden" asp-for="CustomerOrderItems.ElementAt(i).Quantity" />
                            <input type="hidden" asp-for="CustomerOrderItems.ElementAt(i).Price" />
                        }

                        <button type="submit" class="btn-checkout">Финализирай поръчката <i class="fas fa-check-circle ms-2"></i></button>
                    </form>
                </div>
            </div>
        }
    </div>
</div>
