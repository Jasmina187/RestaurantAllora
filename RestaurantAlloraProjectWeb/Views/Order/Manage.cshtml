@using RestaurantAlloraProjectViewModels.Order
@model OrderListViewModel

@{
    ViewData["Title"] = "Всички поръчки";
}

<div class="container mt-5 order-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h2 class="text-danger fw-bold mb-1">
                <i class="fas fa-clipboard-list me-2"></i> Поръчки от клиенти
            </h2>
            <p class="text-muted mb-0">Тук се виждат всички онлайн поръчки, направени от клиентите.</p>
        </div>
        <a asp-controller="Dish" asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-utensils me-1"></i> Към менюто
        </a>
    </div>

    @if (!Model.Orders.Any())
    {
        <div class="alert alert-info shadow-sm rounded">
            <i class="fas fa-info-circle me-2"></i> Все още няма направени клиентски поръчки.
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover bg-white mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>№</th>
                        <th>Дата</th>
                        <th>Клиент</th>
                        <th>Телефон</th>
                        <th>Получаване</th>
                        <th>Статус</th>
                        <th>Сума</th>
                        <th class="text-end">Действие</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Orders)
                    {
                        var statusClass = order.Status switch
                        {
                            "Обработва се" => "bg-warning text-dark",
                            "Отказана" => "bg-danger",
                            "Доставена" => "bg-success",
                            "Готова" => "bg-primary",
                            _ => "bg-info text-dark"
                        };

                        <tr>
                            <td><small class="text-muted">@order.OrderId.ToString().Substring(0, 8)</small></td>
                            <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <div class="fw-semibold">@order.CustomerFullName</div>
                                @if (!string.IsNullOrWhiteSpace(order.CustomerEmail))
                                {
                                    <small class="text-muted">@order.CustomerEmail</small>
                                }
                            </td>
                            <td>@order.CustomerPhone</td>
                            <td>@order.FulfillmentType</td>
                            <td><span class="badge @statusClass">@order.Status</span></td>
                            <td class="fw-bold text-success">@order.TotalAmount.ToString("F2") €</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-info text-dark">
                                    <i class="fas fa-eye"></i> Детайли
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Пагинация на поръчките" class="mt-4">
                <ul class="pagination justify-content-center flex-wrap gap-1">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        @if (Model.HasPreviousPage)
                        {
                            <a class="page-link" asp-action="Manage" asp-route-page="@(Model.CurrentPage - 1)">Предишна</a>
                        }
                        else
                        {
                            <span class="page-link">Предишна</span>
                        }
                    </li>

                    @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                    {
                        <li class="page-item @(pageNumber == Model.CurrentPage ? "active" : "")">
                            @if (pageNumber == Model.CurrentPage)
                            {
                                <span class="page-link">@pageNumber</span>
                            }
                            else
                            {
                                <a class="page-link" asp-action="Manage" asp-route-page="@pageNumber">@pageNumber</a>
                            }
                        </li>
                    }

                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        @if (Model.HasNextPage)
                        {
                            <a class="page-link" asp-action="Manage" asp-route-page="@(Model.CurrentPage + 1)">Следваща</a>
                        }
                        else
                        {
                            <span class="page-link">Следваща</span>
                        }
                    </li>
                </ul>
            </nav>
        }
    }
</div>
