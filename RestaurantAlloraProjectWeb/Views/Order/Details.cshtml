@using RestaurantAlloraProjectViewModels.Order
@model OrderViewModel

@{
    ViewData["Title"] = "Детайли за поръчка";
}

<div class="container mt-5">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-dark text-white p-4">
            <h3 class="mb-0"><i class="fas fa-receipt me-2"></i> Поръчка № @Model.OrderId.ToString().Substring(0, 8)</h3>
            <small>Направена на: @Model.OrderDate.ToString("dd.MM.yyyy HH:mm")</small>
        </div>

        <div class="card-body p-4">
            <div class="row mb-4">
                <div class="col-md-6">
                    <h5 class="text-muted">
                        Статус:
                        <span class="badge bg-info text-dark ms-2" style="font-size: 1rem;">@Model.Status</span>
                    </h5>
                </div>
            </div>

            <h4 class="mb-3 border-bottom pb-2">Артикули:</h4>

            <ul class="list-group list-group-flush mb-4">
                @if (Model.CustomerOrderItems != null)
                {
                    @foreach (var item in Model.CustomerOrderItems)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <div>
                                <span class="fw-bold">@item.DishName</span>
                                <span class="text-muted ms-2">x @item.Quantity</span>
                            </div>
                            <span>@((item.Quantity * item.Price).ToString("F2")) лв.</span>
                        </li>
                    }
                }
            </ul>

            <div class="d-flex justify-content-end border-top pt-3">
                <h4 class="fw-bold text-success">Общо: @Model.TotalAmount.ToString("F2") лв.</h4>
            </div>
        </div>

        <div class="card-footer bg-white p-3 text-center">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-1"></i> Назад към всички поръчки
            </a>
        </div>
    </div>
</div>