@using RestaurantAlloraProject.ViewModels.User
@model ResetPasswordViewModel

<h1 class="text-center">Смяна на парола</h1>
<div class="row">
    <div class="col-md-4 offset-md-4">
        <form asp-action="ResetPassword" method="post">
            <hr />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input asp-for="Token" type="hidden" />
            <input asp-for="EmailAddress" type="hidden" />

            <div class="text-center mb-3">
                <label asp-for="Password" class="form-label">Нова парола</label>
                <input asp-for="Password" type="password" class="form-control" autocomplete="new-password" aria-required="true" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="text-center mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Потвърди новата парола</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" aria-required="true" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="show-reset-passwords" data-toggle-password="#Password,#ConfirmPassword" />
                <label class="form-check-label" for="show-reset-passwords">Покажи паролите</label>
            </div>
            <div class="text-center">
                <button type="submit" class="btn btn-primary">Смени паролата</button>
            </div>
        </form>
    </div>
</div>
