@{
    ViewData["Title"] = "Забравена парола";
}

<div class="row">
    <div class="col-md-6 offset-md-3 text-center">
        <h1>Проверете заявката</h1>
        <p>Ако има профил с този имейл, можете да смените паролата през reset линка.</p>

        @if (ViewBag.ResetPasswordUrl != null)
        {
            <div class="alert alert-info text-start">
                <p class="mb-2">Демо линк за смяна на парола:</p>
                <a href="@ViewBag.ResetPasswordUrl">@ViewBag.ResetPasswordUrl</a>
            </div>
        }

        <a asp-action="LogIn" class="btn btn-primary">Към вход</a>
    </div>
</div>
