@{
    ViewData["Title"] = "Забравена парола";
}

<div class="row">
    <div class="col-md-6 offset-md-3 text-center">
        <h1>Заявка за смяна на парола</h1>

        @if (ViewBag.ResetPasswordUrl != null)
        {
            <p>Намерихме профил с този имейл. Натиснете бутона, за да зададете нова парола.</p>

            <div class="alert alert-info text-start">
                <p class="mb-2">Локален reset линк:</p>
                <a href="@ViewBag.ResetPasswordUrl" class="text-break">@ViewBag.ResetPasswordUrl</a>
            </div>

            <a href="@ViewBag.ResetPasswordUrl" class="btn btn-primary me-2">Смени паролата</a>
        }
        else
        {
            <p>
                Ако има профил с този имейл, заявката е приета. Проверете дали email адресът е въведен правилно.
            </p>
        }

        <a asp-action="LogIn" class="btn btn-secondary">Към вход</a>
    </div>
</div>
