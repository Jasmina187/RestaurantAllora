@using RestaurantAlloraProject.ViewModels.User
@model ForgotPasswordViewModel

<h1 class="text-center">Забравена парола</h1>
<div class="row">
    <div class="col-md-4 offset-md-4">
        <form asp-action="ForgotPassword" method="post">
            <hr />
            <p class="text-muted">Въведете имейла на профила, за да получите линк за смяна на паролата.</p>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="text-center mb-3">
                <label asp-for="EmailAddress" class="form-label">Email</label>
                <input asp-for="EmailAddress" class="form-control" autocomplete="email" aria-required="true" />
                <span asp-validation-for="EmailAddress" class="text-danger"></span>
            </div>
            <div class="d-flex justify-content-between align-items-center">
                <a asp-action="LogIn">Назад към вход</a>
                <button type="submit" class="btn btn-primary">Изпрати</button>
            </div>
        </form>
    </div>
</div>
