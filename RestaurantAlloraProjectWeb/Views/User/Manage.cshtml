@using RestaurantAlloraProject.ViewModels.User
@model IEnumerable<UserListItemViewModel>

@{
    ViewData["Title"] = "Потребители";
}

<div class="container mt-5">
    <h2 class="mb-4">Потребители</h2>

    @if (TempData["UserSuccess"] != null)
    {
        <div class="alert alert-success">@TempData["UserSuccess"]</div>
    }

    @if (TempData["UserError"] != null)
    {
        <div class="alert alert-danger">@TempData["UserError"]</div>
    }

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Потребител</th>
                    <th>Имейл</th>
                    <th>Роля</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.UserName</td>
                        <td>@user.Email</td>
                        <td><span class="badge bg-info text-dark">@user.Role</span></td>
                        <td class="text-end">
                            <a asp-action="Edit"
                               asp-route-id="@user.Id"
                               class="btn btn-sm btn-warning">
                                Редактирай
                            </a>

                            <form asp-action="Delete"
                                  asp-route-id="@user.Id"
                                  method="post"
                                  class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm btn-danger"
                                        data-confirm="Да изтрием ли този потребител?">
                                    Изтрий
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
